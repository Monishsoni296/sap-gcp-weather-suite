Data\ Store\ Entry\ ID=${property.CacheEntryID}
Data\ Store\ Name=Weather_Cache
Expiration\ Period=2
Latitude=${property.Authorization}
Longitude=${header.Latitude}
ProcessDirect\ Address=/fetchWeather
Retention\ Threshold\ for\ Alerting=1
Secure\ Parameter=GCP_API_Key
api-key=${header.Longitude}
enableLogPayload=false
enablePayloadLog=false
unit-system=${header.unitsSystem}
